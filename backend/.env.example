# Backend env template
PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_USER=islacloud
DB_PASSWORD=tu_password_seguro
DB_NAME=islacloud_db
JWT_SECRET=cambia_esta_clave_secreta_por_una_muy_larga_y_segura
JWT_EXPIRES_IN=24h
CORS_ORIGIN=https://www.islacloudsolutions.com
UPLOAD_DIR=./uploads

# SMTP - Notificaciones por email
SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_USER=info@tudominio.com
SMTP_PASS=tu_password
SMTP_FROM_NAME=Isla Cloud Solutions

# DeepL - Auto-traducción CMS (API Free)
DEEPL_API_KEY=tu_api_key_de_deepl

# Compresión PNG (sharp) — todos preservan transparencia
# Logos (clientes/partners/logos): original
LOGO_PNG_QUALITY=85
LOGO_PNG_COMPRESSION_LEVEL=9
LOGO_PNG_EFFORT=7
# Logos: miniatura -thumb.png servida en marquees
LOGO_THUMB_PNG_QUALITY=80
LOGO_THUMB_PNG_COMPRESSION_LEVEL=9
LOGO_THUMB_PNG_EFFORT=8
# PNG genéricos (iconos, etc.)
PNG_QUALITY=82
PNG_COMPRESSION_LEVEL=9
PNG_EFFORT=7
